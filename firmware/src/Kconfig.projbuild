menu "BBClaw"

choice BBCLAW_BOARD_CHOICE
    prompt "Board"
    default BBCLAW_BOARD_BREADBOARD
    help
        Select the target hardware board. Each board defines its own pin map,
        audio codec, display bus, and peripheral configuration.

config BBCLAW_BOARD_BREADBOARD
    bool "Breadboard (INMP441 + MAX98357A + SPI ST7789)"
    help
        Default development configuration using discrete modules on a breadboard.

config BBCLAW_BOARD_ATK_DNESP32S3_BOX
    bool "ATK-DNESP32S3-BOX (ES8311 + i80 ST7789 320x240)"
    help
        Alientek ESP32-S3 development box with ES8311 codec, XL9555 IO expander,
        and 320x240 parallel-interface ST7789 display.

endchoice

menu "Transport"

choice BBCLAW_TRANSPORT_PROFILE_CHOICE
    prompt "Transport Profile"
    default BBCLAW_TRANSPORT_PROFILE_LOCAL_HOME

config BBCLAW_TRANSPORT_PROFILE_LOCAL_HOME
    bool "local_home"
    help
        Directly connect firmware to the local bbclaw-adapter over HTTP.

config BBCLAW_TRANSPORT_PROFILE_CLOUD_SAAS
    bool "cloud_saas"
    help
        Send firmware traffic to BBClaw Cloud. Cloud terminates audio and ASR,
        then relays transcript/reply through Home Adapter.

endchoice

config BBCLAW_ADAPTER_BASE_URL
    string "Local Adapter Base URL"
    depends on BBCLAW_TRANSPORT_PROFILE_LOCAL_HOME
    default "http://192.168.10.26:18080"

config BBCLAW_CLOUD_BASE_URL
    string "Cloud Base URL"
    depends on BBCLAW_TRANSPORT_PROFILE_CLOUD_SAAS
    default "http://bbclaw.daboluo.cc:38082"

config BBCLAW_ENABLE_TTS_PLAYBACK
    bool "Enable TTS Playback"
    default y if BBCLAW_TRANSPORT_PROFILE_CLOUD_SAAS
    default n
    help
        Play back TTS audio from Cloud or Adapter after receiving a reply.

config BBCLAW_ENABLE_DISPLAY_PULL
    bool "Enable Display Pull"
    default y if BBCLAW_TRANSPORT_PROFILE_CLOUD_SAAS
    default n
    help
        Poll Cloud or Adapter for display tasks and show them on screen.

endmenu

menu "Wi-Fi"

config BBCLAW_WIFI_SSID
    string "Default Wi-Fi SSID"
    default ""
    help
        Optional compile-time fallback Wi-Fi SSID. Firmware tries saved slots
        first, then this SSID/password pair if configured.

config BBCLAW_WIFI_PASSWORD
    string "Default Wi-Fi Password"
    default ""
    help
        Optional compile-time fallback Wi-Fi password paired with Default
        Wi-Fi SSID.

endmenu

endmenu
