# ============================================================
# BBClaw Adapter 统一配置
# ============================================================
# ADAPTER_MODE 决定运行模式：
#   "local"  (默认) — HTTP server，接收设备音频流，本地 ASR/TTS
#   "cloud"         — WebSocket relay，通过 BBClaw Cloud 中继
# ============================================================

ADAPTER_MODE=local

# ============================================================
# OpenClaw Gateway（两种模式都需要）
# ============================================================
OPENCLAW_WS_URL=ws://127.0.0.1:18789
OPENCLAW_AUTH_TOKEN=
OPENCLAW_DEVICE_IDENTITY_PATH=
OPENCLAW_NODE_ID=bbclaw-adapter
OPENCLAW_REPLY_WAIT_SECONDS=25

HTTP_TIMEOUT_SECONDS=30

# ============================================================
# Cloud 模式配置（ADAPTER_MODE=cloud 时生效）
# ============================================================
CLOUD_WS_URL=
CLOUD_AUTH_TOKEN=
# 留空则自动从 hostname/machine-id 派生稳定 UUID
HOME_SITE_ID=
CLOUD_RECONNECT_DELAY_SECONDS=3

# ============================================================
# Local 模式配置（ADAPTER_MODE=local 时生效）
# ============================================================

# --- HTTP 服务 ---
ADAPTER_ADDR=:18080
ADAPTER_AUTH_TOKEN=

# --- 音频存储 ---
SAVE_AUDIO=false
SAVE_INPUT_ON_FINISH=true
AUDIO_IN_DIR=tmp/audio-in
AUDIO_OUT_DIR=tmp/audio-out

# --- ASR 语音识别 ---
# 可选 provider: local | openai_compatible | doubao_native
ASR_PROVIDER=local

# local provider — 调用本地命令行工具
ASR_LOCAL_BIN=
# 空格分隔参数，{wav} 会被替换为临时 WAV 路径
# whisper-cpp 示例:
#   ASR_LOCAL_BIN=whisper-cli
#   ASR_LOCAL_ARGS=-m /opt/homebrew/share/whisper-cpp/ggml-base.bin -l zh -f {wav} --no-timestamps -otxt -of {wav}
#   ASR_LOCAL_TEXT_PATH={wav}.txt
# FunASR SenseVoice 示例:
#   ASR_LOCAL_BIN=/path/to/bbclaw/asr/funasr_wrapper.sh
#   ASR_LOCAL_ARGS=-m dummy -f {wav} -l auto --no-timestamps -otxt -of {wav}
ASR_LOCAL_ARGS=
ASR_LOCAL_TEXT_PATH=

# openai_compatible provider
# FunASR 常驻服务示例:
#   ASR_PROVIDER=openai_compatible
#   ASR_BASE_URL=http://127.0.0.1:18081
#   ASR_API_KEY=dummy
#   ASR_MODEL=funasr
ASR_BASE_URL=https://api.openai.com
ASR_API_KEY=
ASR_MODEL=bigmodel

# doubao_native provider
ASR_WS_URL=wss://openspeech.bytedance.com/api/v3/sauc/bigmodel_nostream
ASR_APP_ID=
ASR_RESOURCE_ID=volc.bigasr.sauc.duration
ASR_LANGUAGE=zh-CN

ASR_TRANSCRIBE_TIMEOUT_SECONDS=10
ASR_READINESS_PROBE=1
ASR_READINESS_TIMEOUT_SECONDS=8

# --- TTS 语音合成 ---
# 可选 provider: doubao_native | local_command | mock
TTS_PROVIDER=doubao_native
TTS_WS_URL=wss://openspeech.bytedance.com/api/v1/tts/ws_binary
TTS_APP_ID=
TTS_TOKEN=
TTS_CLUSTER=volcano_tts
TTS_VOICE=zh_female_wanwanxiaohe_moon_bigtts

# --- 流控 ---
MAX_STREAM_SECONDS=90
MAX_AUDIO_BYTES=4194304
MAX_CONCURRENT_STREAMS=16
